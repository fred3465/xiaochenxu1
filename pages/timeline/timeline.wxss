.page { min-height: 100vh; padding: 26rpx; }
.title { font-size: 38rpx; font-weight: 700; color: #28344d; }
.list { margin-top: 24rpx; display: grid; gap: 22rpx; }
.item {
  position: relative; height: 290rpx; border-radius: 24rpx; overflow: hidden;
  box-shadow: 0 14rpx 30rpx rgba(41,58,90,.13);
  animation: fadeInUp .45s ease;
}
.cover { width: 100%; height: 100%; }
.overlay {
  position: absolute; left: 0; right: 0; bottom: 0; padding: 20rpx;
  background: linear-gradient(180deg, rgba(0,0,0,0), rgba(0,0,0,.45));
}
.date { color: #fff; font-size: 22rpx; opacity: .9; }
.desc { display: block; margin-top: 6rpx; color: #fff; font-size: 28rpx; font-weight: 600; }
@keyframes fadeInUp { from { opacity: 0; transform: translateY(14rpx); } to { opacity: 1; transform: translateY(0);} }
